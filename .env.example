GROQ_API_KEY=your_key_here
MLFLOW_TRACKING_URI=./mlruns

# GitHub token (optional — for private repos or higher API rate limits)
# GITHUB_TOKEN=ghp_your_token_here

# Set LLM_BACKEND=modal to use a self-hosted vLLM server on Modal
# LLM_BACKEND=modal
# MODAL_ENDPOINT_URL=https://your-app--serve.modal.run/v1

# Set LLM_BACKEND=foundry to use Llama on Microsoft Foundry (serverless)
# LLM_BACKEND=foundry
# FOUNDRY_ENDPOINT_URL=https://your-deployment.cognitiveservices.azure.com
# FOUNDRY_API_KEY=your_key_here